  {
    "id": "validate_payload",
    "type": "function",
    "z": "tab_iot",
    "name": "Validation payload",
    "func": "const p = msg.payload;\nif (!p || typeof p !== 'object') return null;\nif (!p.device || !p.ts || !p.data) return null;\nif (typeof p.data.temp === 'undefined' || typeof p.data.humidity === 'undefined') return null;\nmsg.payload = p;\nmsg.measurement = {\n    device: p.device,\n    ts: p.ts,\n    temp: Number(p.data.temp),\n    humidity: Number(p.data.humidity),\n    joystickPercent: Number(p.data.joystickPercent || 0),\n    wireContact: p.data.wireContact ? 1 : 0,\n    heap: Number(p.health?.heap || 0),\n    mqttLatencyMs: Number(p.health?.mqttLatencyMs || 0),\n    anomaly: p.health?.anomaly ? 1 : 0,\n    uptime: Number(p.health?.uptime || 0)\n};\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 380,
    "y": 80,
    "wires": [
      [
        "mongodb_document",
        "to_influx_line",
        "dashboard_values",
        "debug_ok"
      ]
    ]
  },
  {
    "id": "mongodb_document",
    "type": "function",
    "z": "tab_iot",
    "name": "Document MongoDB",
    "func": "msg.payload = {\n    device: msg.measurement.device,\n    ts: new Date(msg.measurement.ts * 1000),\n    data: msg.payload.data,\n    health: msg.payload.health || {}\n};\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
    "x": 630,
    "y": 40,
    "wires": [
      [
        "mongo_out"
      ]
    ]
  },
  {
    "id": "mongo_out",
    "type": "mongodb out",
    "z": "tab_iot",
    "mongodb": "mongo_cfg",
    "name": "Stockage NoSQL",
    "collection": "telemetry",
    "payonly": true,
    "upsert": false,
    "multi": false,
    "operation": "insert",
    "x": 880,
    "y": 40,
    "wires": []
  },
  {
    "id": "to_influx_line",
    "type": "function",
    "z": "tab_iot",
    "name": "Line protocol InfluxDB",
    "func": "const m = msg.measurement;\nconst fields = [\n  `temp=${m.temp}`,\n  `humidity=${m.humidity}`,\n  `joystickPercent=${m.joystickPercent}i`,\n  `wireContact=${m.wireContact}i`,\n  `heap=${m.heap}i`,\n  `mqttLatencyMs=${m.mqttLatencyMs}i`,\n  `anomaly=${m.anomaly}i`,\n  `uptime=${m.uptime}i`\n].join(',');\nmsg.payload = `station,device=${m.device} ${fields} ${m.ts}`;\nmsg.headers = {\n    'Authorization': 'Token dev-token-change-me',\n    'Content-Type': 'text/plain; charset=utf-8'\n};\nmsg.url = 'http://influxdb:8086/api/v2/write?org=iot&bucket=esp32&precision=s';\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
    "x": 650,
    "y": 100,
    "wires": [
      [
        "http_influx"
      ]
    ]
  },
  {
    "id": "http_influx",
    "type": "http request",
    "z": "tab_iot",
    "name": "Ecrire InfluxDB",
    "method": "POST",
    "ret": "txt",
    "paytoqs": "ignore",
    "url": "",
    "tls": "",
    "persist": false,
    "proxy": "",
    "insecureHTTPParser": false,
    "authType": "",
    "senderr": false,
    "headers": [],
    "x": 910,
    "y": 100,
    "wires": [
      [
        "debug_influx"
      ]
    ]
  },
  {
    "id": "dashboard_values",
    "type": "function",
    "z": "tab_iot",
    "name": "Valeurs dashboard",
    "func": "const m = msg.measurement;\nreturn [\n  { payload: m.temp, topic: 'temp' },\n  { payload: m.humidity, topic: 'humidity' },\n  { payload: m.joystickPercent, topic: 'joystick' },\n  { payload: m.wireContact ? 'APPUYE' : 'RELACHE', topic: 'wireContact' },\n  { payload: m.heap, topic: 'heap' },\n  { payload: m.mqttLatencyMs, topic: 'latency' },\n  { payload: m.anomaly ? 'ANOMALIE' : 'OK', topic: 'anomaly' }\n];",
    "outputs": 7,
    "noerr": 0,
    "x": 640,
    "y": 180,
    "wires": [
      [
        "ui_temp",
        "ui_chart_temp"
      ],
      [
        "ui_humidity"
      ],
      [
        "ui_joystick"
      ],
